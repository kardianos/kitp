# demo | doc="Opt-in dev fixture data: Default Project + sample tasks."

-- Demo seed. Replaces the ~200-line PL/pgSQL DO block in
-- declarative.toml. The loader wraps every statement in a single
-- DO $demo$ … END $demo$ that returns early when the card table
-- already has rows (see hcsv.SeedOptions.GuardDemo).
--
-- Wait — except the loader can't safely wrap a CTE-chain INSERT in
-- a DO block (PL/pgSQL needs PERFORM for trailing SELECT). For demo
-- emission we therefore set GuardDemo=true and the loader emits
-- DO $demo$ BEGIN IF … END; … END $demo$, with each card row's
-- CTE chain replaced by PERFORM-style execution. The simpler
-- approach actually used: rely on the @-alias / $-lookup chain
-- emitting INSERTs in topological order; the DO block hosts every
-- INSERT/PERFORM line. See seed.go.
--
-- Naming conventions used below:
--  - aliases prefixed `m_`, `c_`, `t_`, `s_` for milestone /
--    component / tag / status. Tasks have no alias (none are
--    referenced by sibling rows).
--  - All non-project cards declare `parent_card_id, parent` to
--    pick up the project's id via heading nesting (the project
--    section's single row is the resolved parent for every
--    `under=proj_default` section).


-- Dev team. Real users come from OIDC in production; these are the
-- sample users every dev DB ships with so the UI looks lived-in and
-- assignee dropdowns have realistic options. The user_account /
-- person-card / user_account_person rows live together so a clean
-- re-apply of the demo doesn't half-create the dev team.

## table user_account | on_conflict="id" | reset_sequence=user_account_id_seq
### rows
id, display_name, email
2, alice, alice@example.invalid
3, bob,   bob@example.invalid
4, carol, carol@example.invalid
5, dave,  dave@example.invalid
6, eve,   eve@example.invalid


## table user_role | doc="Dev team gets 'admin' so any AUTH_MODE=off impersonation flow lands on a user that can do everything in the UI." | on_conflict="*"
### rows
user_id, role_id, scope_card_id
2, $role.admin, null
3, $role.admin, null
4, $role.admin, null
5, $role.admin, null
6, $role.admin, null


## table card | doc="Person cards for the dev team. Explicit ids 2..6 mirror user_account ids so demo task assignees resolve by id without lookups. reset_sequence advances card_id_seq past these explicit ids so the subsequent auto-id inserts (project, milestones, …) start at 7+." | on_conflict="id" | reset_sequence=card_id_seq
### rows
id, card_type_id,       title,   email,                 alias
2, $card_type.person,  alice,   alice@example.invalid, person_alice
3, $card_type.person,  bob,     bob@example.invalid,   person_bob
4, $card_type.person,  carol,   carol@example.invalid, person_carol
5, $card_type.person,  dave,    dave@example.invalid,  person_dave
6, $card_type.person,  eve,     eve@example.invalid,   person_eve


## table user_account_person | on_conflict="user_account_id"
### rows
user_account_id, person_card_id
2, @person_alice
3, @person_bob
4, @person_carol
5, @person_dave
6, @person_eve


## table card | alias=proj_default
### rows
card_type_id, title
$card_type.project, "Default Project"


