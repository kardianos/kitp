## table flow | doc="One state-machine definition, scoped to one project. Each row binds a flow to one (attribute_def, project) pair — the attribute_def names the attribute whose value cards are the flow's states, and the project is the scope under which this flow applies. There are no global / install-wide flows; templates live in the install seed and are stamped into each new project at seed time (Gate 11). default_create_status_id names the status this flow assigns to a new task when a screen using this flow has no per-screen override." | unique="attribute_def_id, scope_card_id"

### meta
name_column
name

### columns
name, type, pk, nullable, default, references, on_delete
id, bigserial, true, , , ,
name, text, , false, , ,
doc, text, , , , ,
attribute_def_id, bigint, , false, , attribute_def.id,
scope_card_id, bigint, , false, , card.id, cascade
default_create_status_id, bigint, , , , card.id,
created_at, timestamptz, , false, now(), ,


## table flow_step | doc="One transition edge in a flow. from_card_id and to_card_id both point at value cards on the same attribute_def as the flow. Tasks always have a real status value-card (status is a required attribute), so there is no 'from unset' case — every transition is real → real. label is the button text; the UI category (Accept / Reject / Close / Reopen / progress) is derived at render time from (from_card.phase, to_card.phase). requires_role_id NULL means any authenticated user. sort_order orders entries within the same UI bucket for deterministic rendering." | unique="flow_id, from_card_id, to_card_id, label"

### columns
name, type, pk, nullable, default, references, on_delete
id, bigserial, true, , , ,
flow_id, bigint, , false, , flow.id, cascade
from_card_id, bigint, , false, , card.id,
to_card_id, bigint, , false, , card.id,
label, text, , false, , ,
requires_role_id, bigint, , , , role.id,
sort_order, int, , false, 0, ,
created_at, timestamptz, , false, now(), ,


## table comm_secret | doc="Encrypted IMAP/SMTP passwords for a comm_channel card. One row per channel; channel_card_id is the PK and FK with ON DELETE CASCADE so deleting the channel drops the secret. imap_password and smtp_password are bytea cells written via pgcrypto's sym_encrypt (key from KITP_COMM_SECRET_KEY env var) — Gate 3 wires the encryption; Gate 1 only ships the column shape."

### columns
name, type, pk, nullable, default, references, on_delete
channel_card_id, bigint, true, , , card.id, cascade
imap_password, bytea, , , , ,
smtp_password, bytea, , , , ,
updated_at, timestamptz, , false, now(), ,


## table comm_log | doc="Per-project ring buffer of channel-level events (poll cycles, send attempts, bounces, parse errors). Decoupled from cards because the volume is high and a parse error before identification has no card to attach to. Retention via a periodic prune gated by KITP_COMM_LOG_RETENTION_DAYS."

### columns
name, type, pk, nullable, default, references, on_delete
id, bigserial, true, , , ,
project_id, bigint, , false, , card.id,
channel_id, bigint, , , , card.id,
kind, text, , false, , ,
detail, jsonb, , , , ,
at, timestamptz, , false, now(), ,

### indexes
name, columns
idx_comm_log_project_at, "project_id, at desc"
idx_comm_log_project_kind_at, "project_id, kind, at desc"
