@flow_default,   @s_todo,       @s_doing,    "Start",          1,          false
@flow_default,   @s_doing,      @s_review,   "Send to review", 1,          false
@flow_default,   @s_review,     @s_done,     "Approve",        1,          true
@flow_default,   @s_doing,      @s_done,     "Done",           2,          true
@flow_default,   @s_todo,       @s_done,     "Done",           3,          true
@flow_default,   @s_todo,       @s_cancel,   "Cancel",         4,          false
@flow_default,   @s_doing,      @s_cancel,   "Cancel",         5,          false
@flow_default,   @s_review,     @s_cancel,   "Cancel",         6,          false
@flow_default,   @s_done,       @s_todo,     "Reopen",         1,          true
@flow_default,   @s_cancel,     @s_todo,     "Reopen",         2,          true


