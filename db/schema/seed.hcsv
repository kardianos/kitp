### rows
user_account_id, person_card_id
1, 1


-- role_grant. Cross-products are expressed with array-expansion in
-- attribute cells; the loader emits one INSERT per element-tuple.

## table role_grant | doc="system role: every (card_type, process) tuple. Carries every grant for AUTH_MODE=off." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.system, `[$card_type.project, $card_type.task, $card_type.milestone, $card_type.component, $card_type.tag, $card_type.status, $card_type.comment_body, $card_type.person, $card_type.screen, $card_type.filter]`, `[$process."card.create", $process."card.update", $process."card.delete", $process."comment.post", $process."task.update_with_comment", $process."user_card_sort.set"]`


## table role_grant | doc="commenter grants: only comment.post on task." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.commenter, $card_type.task, $process."comment.post"


## table role_grant | doc="worker grants: act on task (update/comment/personal-sort)." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.worker, $card_type.task, `[$process."card.update", $process."comment.post", $process."user_card_sort.set"]`


## table role_grant | doc="manager grants: worker grants on task + create/update/delete on project/milestone/component/tag/screen/filter/status." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.manager, $card_type.task, `[$process."card.update", $process."comment.post", $process."user_card_sort.set"]`
$role.manager, `[$card_type.project, $card_type.milestone, $card_type.component, $card_type.tag, $card_type.screen, $card_type.filter, $card_type.status]`, `[$process."card.create", $process."card.update", $process."card.delete"]`


## table role_grant | doc="admin grants: card.* + comment.post + user_card_sort.set across every built-in card_type. status is included so admins can manage value-cards for the flow kernel (V8: delete is gated against flow_step references)." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.admin, `[$card_type.project, $card_type.task, $card_type.milestone, $card_type.component, $card_type.tag, $card_type.person, $card_type.screen, $card_type.filter, $card_type.status]`, `[$process."card.create", $process."card.update", $process."card.delete", $process."comment.post", $process."user_card_sort.set"]`


-- ---------------------------------------------------------------------
-- Standard Project Template (Gate 11 of docs/FLOW_AND_SCREEN_KERNEL.md)
--
-- The template is a real `project` card flagged `is_template=true`. It
-- carries the kernel default set: 6 status value-cards (one triage,
-- three active, two terminal), the standard `status` flow with its
-- default_create_status pointing at "New idea", 12 flow_step transitions,
-- and the 6 default screens (Inbox / Grid / Kanban / Project / Ideas /
-- Archive) with layouts, slugs, hotkeys, flow_refs, default_create_status
-- overrides and toggle_groups.
--
-- New projects are produced by `project.stamp` (Gate 10), which graph-
-- copies the template's value cards, flows, flow_steps, screens, and
-- filter children into the fresh project with ID remapping.
--
-- Idempotency: every row carries an explicit id and on_conflict="id" so a
-- re-apply of the install seed is a true no-op. The demo guard skips its
-- own load when ANY non-template project exists (see seed.go), so the
-- template's presence does not block dev / test fixture loads.

## table card | alias=tpl_project | doc="The template project itself. is_template=true marks it as a stamping source; the user-facing project list filters it out client-side (Gate 12)." | on_conflict="id"
### rows
id, card_type_id,        title,                          is_template
10, $card_type.project,  "Standard Project Template",    true


## table card | under=tpl_project | doc="Template status value-cards. phase classifies each row for has_phase predicates and the default-create-status resolution chain (Gate 6). 'New idea' is the lone triage row and the flow's default_create_status_id." | on_conflict="id"
### rows
id, card_type_id,     parent_card_id, phase,    title,       sort_order, alias
11, $card_type.status, parent,         triage,   "New idea",  5,          tpl_s_idea
12, $card_type.status, parent,         active,   "Todo",      10,         tpl_s_todo
13, $card_type.status, parent,         active,   "Doing",     20,         tpl_s_doing
14, $card_type.status, parent,         active,   "Review",    30,         tpl_s_review
15, $card_type.status, parent,         terminal, "Done",      40,         tpl_s_done
16, $card_type.status, parent,         terminal, "Cancelled", 50,         tpl_s_cancel


## table flow | doc="Standard task flow for the template. Binds the `status` attribute to the template project; new projects get a stamped copy via project.stamp." | on_conflict="attribute_def_id, scope_card_id"
### rows
name,             attribute_def_id,        scope_card_id, default_create_status_id, alias
"Standard task",  $attribute_def.status,   @tpl_project,  @tpl_s_idea,              tpl_flow_status


## table flow_step | doc="12 transitions for the standard status flow. Buckets (from.phase, to.phase) drive the TransitionBar's UI category: triage→active = Accept, triage→terminal = Reject, active→active = progress, active→terminal = Close, terminal→active = Reopen." | on_conflict="flow_id, from_card_id, to_card_id, label"
### rows
flow_id,           from_card_id,  to_card_id,     label,             sort_order
@tpl_flow_status,  @tpl_s_idea,   @tpl_s_todo,    "Accept",          1
@tpl_flow_status,  @tpl_s_idea,   @tpl_s_cancel,  "Reject",          2
@tpl_flow_status,  @tpl_s_todo,   @tpl_s_doing,   "Start",           1
@tpl_flow_status,  @tpl_s_doing,  @tpl_s_review,  "Send to review",  1
@tpl_flow_status,  @tpl_s_review, @tpl_s_done,    "Approve",         1
@tpl_flow_status,  @tpl_s_doing,  @tpl_s_done,    "Done",            2
@tpl_flow_status,  @tpl_s_todo,   @tpl_s_done,    "Done",            3
@tpl_flow_status,  @tpl_s_todo,   @tpl_s_cancel,  "Cancel",          4
@tpl_flow_status,  @tpl_s_doing,  @tpl_s_cancel,  "Cancel",          5
@tpl_flow_status,  @tpl_s_review, @tpl_s_cancel,  "Cancel",          6
@tpl_flow_status,  @tpl_s_done,   @tpl_s_todo,    "Reopen",          1
@tpl_flow_status,  @tpl_s_cancel, @tpl_s_todo,    "Reopen",          2


-- Template screens. Six screen cards, all six built-in layouts. The
-- toggle_groups attribute is a JSON-text predicate-tree spec consumed by
-- the client's filter bar; each spec composes the screen's phase scope
-- and (for Inbox) the actor-only filter. The two net-new screens — Ideas
-- and Archive — surface triage / terminal rows respectively. flow_ref
-- points at the template's status flow; default_create_status overrides
-- the flow's default for Inbox ("Todo") and Ideas ("New idea").

## table card | under=tpl_project | doc="Inbox screen. Active tasks assigned to the actor; default-create-status overrides the flow default ('New idea') to 'Todo' since the Inbox is about starting work, not filing ideas." | on_conflict="id"
### rows
id, card_type_id,     parent_card_id, title,   layout, slug,  hotkey, sort_order, flow_ref,           default_create_status, toggle_groups
17, $card_type.screen, parent,         "Inbox", list,   inbox, i,      1,          @tpl_flow_status,  @tpl_s_todo,           `[{"name":"phase_scope","operator":"or","mode":"multi","items":[{"name":"active","label":"Active","predicate":{"attr":"status","op":"has_phase","values":["active"]},"default_on":true}]},{"name":"scope","operator":"and","mode":"multi","items":[{"name":"mine_only","label":"Mine","predicate":{"attr":"assignee","op":"=","values":["__actor__"]},"default_on":true}]}]`


## table card | under=tpl_project | doc="Grid screen. Phase items are independent checkboxes so the user can flip triage / terminal on alongside the active default." | on_conflict="id"
### rows
id, card_type_id,     parent_card_id, title,  layout, slug, hotkey, sort_order, flow_ref,          toggle_groups
18, $card_type.screen, parent,         "Grid", grid,   grid, g,      2,          @tpl_flow_status, `[{"name":"phase_scope","operator":"or","mode":"multi","items":[{"name":"triage","label":"Triage","predicate":{"attr":"status","op":"has_phase","values":["triage"]},"default_on":false},{"name":"active","label":"Active","predicate":{"attr":"status","op":"has_phase","values":["active"]},"default_on":true},{"name":"terminal","label":"Closed","predicate":{"attr":"status","op":"has_phase","values":["terminal"]},"default_on":false}]}]`


## table card | under=tpl_project | doc="Kanban screen. Columns are status value-cards; toggle the terminal phase item to include Done/Cancelled columns." | on_conflict="id"
### rows
id, card_type_id,     parent_card_id, title,    layout, slug,   hotkey, sort_order, flow_ref,          column_attr, toggle_groups
19, $card_type.screen, parent,         "Kanban", kanban, kanban, k,      3,          @tpl_flow_status, status,      `[{"name":"phase_scope","operator":"or","mode":"multi","items":[{"name":"active","label":"Active","predicate":{"attr":"status","op":"has_phase","values":["active"]},"default_on":true},{"name":"terminal","label":"Closed","predicate":{"attr":"status","op":"has_phase","values":["terminal"]},"default_on":false}]}]`


## table card | under=tpl_project | doc="Project detail (pair layout). No hotkey — entered via the project list." | on_conflict="id"
### rows
id, card_type_id,     parent_card_id, title,     layout, slug,    sort_order, flow_ref,          toggle_groups
20, $card_type.screen, parent,         "Project", pair,   project, 4,          @tpl_flow_status, `[{"name":"phase_scope","operator":"or","mode":"multi","items":[{"name":"active","label":"Active","predicate":{"attr":"status","op":"has_phase","values":["active"]},"default_on":true}]}]`


## table card | under=tpl_project | doc="Ideas screen (NEW in Gate 11). Triage-phase rows only; default_create_status overrides the flow default so a 'g n' quick-entry lands as 'New idea'." | on_conflict="id"
### rows
id, card_type_id,     parent_card_id, title,   layout, slug,  hotkey, sort_order, flow_ref,          default_create_status, toggle_groups
