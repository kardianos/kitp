# seed | doc="Install-level rows applied to every kitp DB."

-- Install seed. See db/schema/schema.hcsv for the table definitions
-- and docs/hcsv_strawman/README.md for the file-format spec.


## table user_account | doc="System User (id=1). The only user every install needs; lets AUTH_MODE=off start with a working actor and gives automated jobs / activity rows a stable actor_id=1. Real users come from OIDC; dev / demo teams live in demo.hcsv." | on_conflict="id" | reset_sequence=user_account_id_seq
### rows
id, display_name, email
1, System,


## table role | doc="Built-in roles. 'system' holds every grant for AUTH_MODE=off; the others are the OIDC role model." | on_conflict="name"
### rows
name
system
viewer
commenter
worker
manager
admin


## table user_role | doc="System User gets both 'system' (every grant; AUTH_MODE=off) and 'admin' (so the BFF dev session unlocks Admin UI affordances). Demo / dev team grants live in demo.hcsv." | on_conflict="*"
### rows
user_id, role_id, scope_card_id
1, $role.system, null
1, $role.admin,  null


## table role_mapping | doc="Default OIDC group → role mappings for the dex dev stack." | on_conflict="claim_value"
### rows
claim_value, role_id
kitp.admin,   $role.admin
kitp.manager, $role.manager
kitp.worker,  $role.worker


## table card_type | doc="Built-in card types. project / task / milestone / component / tag / status / screen / filter are project-scoped (parent_card_type_id=project). person + comment_body are global. filter cards parent under screen." | on_conflict="name"
### rows
name, is_built_in, allow_self_parent, parent_card_type_id
project,      true,  false, null
task,         true,  true,  $card_type.project
milestone,    true,  false, $card_type.project
component,    true,  false, $card_type.project
tag,          true,  true,  $card_type.project
status,       true,  false, $card_type.project
comment_body, true,  false, null
person,       true,  false, null
screen,       true,  false, $card_type.project
filter,       true,  false, $card_type.screen


