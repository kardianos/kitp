# seed | doc="Install-level rows applied to every kitp DB."

-- Install seed. See db/schema/schema.hcsv for the table definitions
-- and docs/hcsv_strawman/README.md for the file-format spec.


## table user_account | doc="System User (id=1). The only user every install needs; lets AUTH_MODE=off start with a working actor and gives automated jobs / activity rows a stable actor_id=1. Real users come from OIDC; dev / demo teams live in demo.hcsv." | on_conflict="id" | reset_sequence=user_account_id_seq
### rows
id, display_name, email
1, System,


## table role | doc="Built-in roles. The OIDC role model; no wildcard role — every grant is explicit so production and dev resolve through identical code paths." | on_conflict="name"
### rows
name
viewer
commenter
worker
manager
admin


## table user_role | doc="System User holds admin + manager + worker globally — explicit grants instead of the old 'system' wildcard, so the role-gate / LoadUserRoles paths don't carry a special case. Demo / dev team grants live in demo.hcsv." | on_conflict="*"
### rows
user_id, role_id,         scope_card_id
1,       $role.admin,     null
1,       $role.manager,   null
1,       $role.worker,    null


## table role_mapping | doc="Default OIDC group → role mappings for the dex dev stack." | on_conflict="claim_value"
### rows
claim_value, role_id
kitp.admin,   $role.admin
kitp.manager, $role.manager
kitp.worker,  $role.worker


## table card_type | doc="Built-in card types. project / task / milestone / component / tag / status / screen / filter / comm_channel / activity_sink are project-scoped (parent_card_type_id=project). person + comment_body + reply_body are global. filter cards parent under screen. comm cards parent under task. uses_phase=true marks card_types whose instances are flow-bound value-cards — the `phase` column on those rows is consulted by the predicate compiler (has_phase op) and the TransitionBar UI. Tasks / projects / etc. carry the column but never read it." | on_conflict="name"
### rows
name,              is_built_in, allow_self_parent, parent_card_type_id,    uses_phase
project,           true,        false,             null,                   false
task,              true,        true,              $card_type.project,     false
milestone,         true,        false,             $card_type.project,     false
component,         true,        false,             $card_type.project,     false
tag,               true,        true,              $card_type.project,     false
status,            true,        false,             $card_type.project,     true
comment_body,      true,        false,             null,                   false
person,            true,        false,             null,                   false
screen,            true,        false,             $card_type.project,     false
filter,            true,        false,             $card_type.screen,      false
comm_channel,      true,        false,             $card_type.project,     false
comm,              true,        false,             $card_type.task,        false
reply_body,        true,        false,             null,                   false
activity_sink,     true,        false,             $card_type.project,     false
predicate_snippet, true,        false,             $card_type.project,     false


