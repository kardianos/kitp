# db | doc="Canonical kitp database schema. Tables/indexes/extensions live here; seed/demo rows live in declarative.toml until the seed loader migrates too."

## prop
name, value
extension, pg_trgm
extension, pgcrypto


## table user_account | doc="Users. id=1 is the System User used by AUTH_MODE=off. email and oidc_sub identify OIDC subjects. parent_user_id (self-FK) names the human owner when is_agent=true — agents are user_account rows owned by another user_account, with role rows scoped to a parent-granted subset and token-only authentication (see user_token). ON DELETE CASCADE so deleting a human deletes every agent they own."

### meta
name_column
display_name

### columns
name, type, pk, unique, nullable, default, references, on_delete
id, bigserial, true, , , , , 
oidc_sub, text, , true, , , , 
display_name, text, , , false, , , 
email, text, , , , , , 
parent_user_id, bigint, , , , , user_account.id, cascade
is_agent, boolean, , , false, false, , 
created_at, timestamptz, , , false, now(), , 

## table session | doc="Server-side session for the BFF auth model. The opaque `id` is what the kitp_session cookie carries (never the OIDC token). `created_at` anchors the absolute re-auth cap; `last_seen_at` is the sliding idle window updated by Manager batched-touch flushes. `revoked_at` set on logout / admin revoke. `oidc_sub` records the OP subject for OIDC sessions so we can rotate when sub changes."

### columns
name, type, pk, nullable, default, references, on_delete
id, text, true, , , , 
user_id, bigint, , false, , user_account.id, cascade
created_at, timestamptz, , false, now(), , 
last_seen_at, timestamptz, , false, now(), , 
revoked_at, timestamptz, , , , , 
oidc_sub, text, , , , , 

### indexes
name, columns
session_user_id, "user_id"
session_last_seen_at, "last_seen_at"

## table oidc_state | doc="Short-lived PKCE staging for the server-managed OIDC redirect dance. /auth/oidc/start writes a row keyed by `state`; /auth/oidc/callback reads + deletes it. Rows past `expires_at` are reaped by a periodic sweep."

### columns
name, type, pk, nullable, default
state, text, true, , 
verifier, text, , false, 
redirect, text, , false, '/'
created_at, timestamptz, , false, now()
expires_at, timestamptz, , false, 

### indexes
name, columns
oidc_state_expires_at, "expires_at"

## table user_token | doc="Opaque bearer tokens that authenticate an MCP (or future remote) client AS a specific user_account row. Typical use: a human mints a token bound to one of their agent user_accounts, hands it to the MCP client out-of-band. The value is 32 random bytes base64url-encoded — same shape as session.id — and is looked up directly; nothing meaningful is embedded. last_used_at participates in the same batched-touch pattern as session.last_seen_at. ON DELETE CASCADE so revoking the agent user_account row revokes every token bound to it. label is required and unique per user so user_token.list / user_token.revoke can address rows without leaking the secret value back to the wire — list returns labels + timestamps, revoke takes (user_id, label)." | unique="user_id, label"

### columns
name, type, pk, nullable, default, references, on_delete
id, text, true, , , , 
user_id, bigint, , false, , user_account.id, cascade
label, text, , false, , , 
created_at, timestamptz, , false, now(), , 
last_used_at, timestamptz, , false, now(), , 
revoked_at, timestamptz, , , , , 
expires_at, timestamptz, , , , , 

### indexes
name, columns
user_token_user_id, "user_id"
user_token_last_used_at, "last_used_at"

## table user_card_agent | doc="Per-(parent-user, card) routing of a task to one of the parent's agents. The parent owns the assignment; other users in the project never see it. The agent's inbox query joins this table on `agent_user_id = me AND user_id = my_parent`. PK (user_id, card_id) limits one card to one routed agent per parent — sufficient for 'alice has card 42 routed to her research agent' without enabling cross-agent fan-out, which would just be confusing." | primary_key="user_id, card_id"

### columns
name, type, nullable, default, references, on_delete
user_id, bigint, false, , user_account.id, cascade
card_id, bigint, false, , card.id, cascade
agent_user_id, bigint, false, , user_account.id, cascade
created_at, timestamptz, false, now(), , 

### indexes
name, columns
user_card_agent_agent_user_id, "agent_user_id"

