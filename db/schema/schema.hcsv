last_error, text, , , , ,
updated_at, timestamptz, , false, now(), ,

-- ---------------------------------------------------------------------
-- Handler functions (unified handler model — docs/UNIFIED_HANDLER_PLAN.md).
-- Every batch handler with `reg.Handler.SQLFunc` set has its body here.
-- Signature is `(actor_id bigint, inputs jsonb) RETURNS TABLE(idx int,
-- ok boolean, code text, message text, result jsonb)` — uniform so the
-- dispatcher's wrapper code is one shape.
-- ---------------------------------------------------------------------

## function card_ancestors | doc="Shared capped parent_card_id walk (A1 / BE-C1 / SEC-1). Returns the ancestor chain of a card (inclusive) with a 0-based depth column; the recursive arm carries WHERE depth < 16 so a parent cycle can't pin a connection. The single source of the depth cap (A15d)." | path="functions/card_ancestors.sql" | arg_types="bigint"
## function card_enclosing_project | doc="Resolve a card's enclosing project (first card_type='project' ancestor within the depth cap) via card_ancestors. Canonical card→project resolver (A10 / BE-M3); declared after card_ancestors because its SQL body references it at create time." | path="functions/card_enclosing_project.sql" | arg_types="bigint"
## function card_ref_cross_project | doc="Check whether a card's stored card_ref / card_ref[] values would cross a project boundary for a given target enclosing project (A11 / BE-M5). Returns the first offending (attr, value_card, value_project) or no rows. Reuses card_enclosing_project; declared after it. Used by card.move to re-validate the cross-project ref invariant on re-parent." | path="functions/card_ref_cross_project.sql" | arg_types="bigint, bigint"
## function comment_insert_batch | doc="comment.insert — validate + write per row." | path="functions/comment_insert_batch.sql"
## function build_flow_available_array | doc="V13 helper: emits the available[] JSONB array for a flow rejection envelope. Mirrors flow.listAvailableTransitions in PL/pgSQL." | path="functions/build_flow_available_array.sql" | arg_types="bigint, bigint, bigint"
## function attribute_update_batch | doc="attribute.update — validate (card / edge / required-removal / project-scope / screen-uniqueness / flow gate) and write per row." | path="functions/attribute_update_batch.sql"
## function attachment_delete_batch | doc="attachment.delete — soft-delete + activity row per input." | path="functions/attachment_delete_batch.sql"
## function attachment_create_batch | doc="attachment.create — validate + link existing file to card + activity row per input; thumb_file_id is NULL at SQL level and the dispatcher's PostRun hook (doThumbnails) fills it in after Go-side image decode." | path="functions/attachment_create_batch.sql"
## function remap_predicate_tree | doc="Walk a predicate-tree JSONB value and rewrite card_ref ids on every leaf whose attr names a card_ref / card_ref[] attribute. Recurses into children[] (connective nodes) and items[].predicate (toggle_groups). Used by copy_project_template." | path="functions/remap_predicate_tree.sql" | arg_types="jsonb, jsonb, text[]"
## function copy_project_template | doc="Graph-copy a template project's descendants (cards + flows + flow_steps + attribute_values with ID remap, including predicate-tree card-ref remap via remap_predicate_tree) into a fresh new_project_id. Used by card.insert(project) and project_stamp_batch." | path="functions/copy_project_template.sql" | arg_types="bigint, bigint, bigint"
## function card_insert_batch | doc="card.insert — validate (card_type / parent / required-edges / scope) and write card + activities + initial attribute values per input. Seeds built-in screens for projects." | path="functions/card_insert_batch.sql"
## function card_delete_batch | doc="card.delete — soft-delete + activity row per input, with flow_step reference guard." | path="functions/card_delete_batch.sql"
## function card_move_batch | doc="card.move — re-parent + activity row per input, with parent-type compatibility check." | path="functions/card_move_batch.sql"
## function card_set_phase_batch | doc="card.set_phase — write the structural phase column + activity row per input." | path="functions/card_set_phase_batch.sql"
## function project_stamp_batch | doc="project.stamp — INSERT a fresh project card + title + is_template=FALSE attribute_values, then PERFORM copy_project_template to graph-copy the template's descendants (status / milestone / screen / filter / predicate_snippet cards + flows + flow_steps + attribute_values with full ID remap). Emits V24 warnings (template_empty / template_no_flows)." | path="functions/project_stamp_batch.sql"
## function task_move_batch | doc="task.move — bump task (and optionally its parent_task subtree) to a different project, clearing per-project classification." | path="functions/task_move_batch.sql"
## function task_purge_batch | doc="task.purge — hard delete a task and cascade comms / reply_bodies / attachments / activity." | path="functions/task_purge_batch.sql"
## function comment_update_batch | doc="comment.update — validate + author-check + body update + audit row per input." | path="functions/comment_update_batch.sql"
## function user_card_sort_set_batch | doc="user_card_sort.set — validate + per-user upsert per input." | path="functions/user_card_sort_set_batch.sql"
