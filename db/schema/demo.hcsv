## table card | under=proj_default | doc="Status value-cards. phase classifies each status row for the predicate compiler's has_phase op and the legacy notTerminal alias: triage statuses surface in inbox/triage flows; active statuses are the in-flight queue; terminal statuses (Done, Cancelled) are hidden by has_phase ∈ {triage, active} filters."
### rows
card_type_id,     parent_card_id, phase,    title,       sort_order, alias
$card_type.status, parent,         triage,   "New idea",  0,         s_new_idea
$card_type.status, parent,         active,   "Todo",      1,         s_todo
$card_type.status, parent,         active,   "Doing",     2,         s_doing
$card_type.status, parent,         active,   "Review",    3,         s_review
$card_type.status, parent,         terminal, "Done",      4,         s_done
$card_type.status, parent,         terminal, "Cancelled", 5,         s_cancel


## table flow | doc="Standard task flow for Default Project, mirroring the template's shape but bound to this project's status cards. Name is project-suffixed because the loader's flow ref-lookup is by name alone (the table doesn't expose a name+scope composite lookup), so multiple flows sharing 'Standard task' across the template + the demo projects would collide. Without a flow, TransitionBar renders nothing and the task-detail status pickers can't show labelled transitions." | on_conflict="attribute_def_id, scope_card_id"
### rows
name,                            attribute_def_id,      scope_card_id, default_create_status_id, alias
"Default Project status flow",   $attribute_def.status, @proj_default, @s_new_idea,              flow_default


## table flow_step | doc="12 transitions copied from the template's task flow. Buckets (from.phase, to.phase) drive the TransitionBar's UI category: triage→active = Accept, triage→terminal = Reject, active→active = progress, active→terminal = Close, terminal→active = Reopen." | on_conflict="flow_id, from_card_id, to_card_id, label"
### rows
flow_id,         from_card_id,  to_card_id,  label,            sort_order, standalone
@flow_default,   @s_new_idea,   @s_todo,     "Accept",         1,          true
