# db | doc="Canonical kitp database schema (strawman slice)"

-- hcsv format strawman — schema definition.
--
-- Format overview (see README.md for the full spec attempt):
--   - Markdown-style headings (#, ##, ###) define parent-child hierarchy.
--     Depth is structural; no fixed depth conventions.
--   - `# db` is the root.
--   - `## prop` carries db-wide properties (extensions, etc).
--   - `## table <name>` declares a table.
--   - Under a table: `### meta`, `### columns`, `### indexes`.
--   - First non-blank line after a heading is the column header; subsequent
--     non-blank lines are rows.
--   - Pipe-delimited modifiers on headings: `# table foo | alias=bar`.
--   - `null` literal = SQL NULL; empty cell = column default / null.
--   - `$<table>.<name>` = lookup by the table's `name_column` (defined in meta).
--   - `@<alias>` = reference a row by alias.
--   - `parent` = the immediately-enclosing parent row's id.
--   - Strings with commas/spaces/quotes wrap in `"..."` (CSV-style escape: `""` inside).
--   - SQL-style `--` line comments. Block comments not supported.

## prop
name, value
extension, pg_trgm


## table user_account | doc="Users. id=1 is the System User used by AUTH_MODE=off."

### meta
name_column, id_column
display_name, id

### columns
name, type, pk, unique, nullable, default, references, on_delete
id, bigserial, true, false, false, , ,
oidc_sub, text, false, true, true, , ,
display_name, text, false, false, false, , ,
email, text, false, false, true, , ,
parent_user_id, bigint, false, false, true, , user_account.id, cascade
is_agent, boolean, false, false, false, false, ,
created_at, timestamptz, false, false, false, now(), ,


## table role | doc="Application role. Assigned to users via user_role."

### meta
name_column, id_column
name, id

### columns
name, type, pk, nullable, default
id, bigserial, true, false,
name, text, false, false,
doc, text, false, true,

### indexes
name, columns, unique
role_name_uniq, name, true


## table user_role | doc="Assigns a role to a user, optionally scoped to a card subtree. m:n table; no name_column."

### columns
name, type, pk, nullable, default, references, on_delete
id, bigserial, true, false, , ,
user_id, bigint, false, false, , user_account.id, cascade
role_id, bigint, false, false, , role.id, cascade
scope_card_id, bigint, false, true, , card.id, cascade

### indexes
name, columns, unique
user_role_uniq, "user_id, role_id, scope_card_id", true


