-- role_grant. Cross-products are expressed with array-expansion in
-- attribute cells; the loader emits one INSERT per element-tuple.

## table role_grant | doc="commenter grants: only comment.post on task." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.commenter, $card_type.task, $process."comment.post"


## table role_grant | doc="worker / manager: SHARED surface — task create + update + comment + sort, comm create + update + comment + sort (so workers can set a comm channel on a task and reply via reply.post which gates on (comm, card.update)), person create + update (so adding a teammate / contact doesn't require admin), and CRUD on the structural cards a worker legitimately authors (project / screen / filter / status / predicate_snippet). The MANAGER-ONLY grant below adds CRUD on the enum_managed VALUE cards (milestone / component / tag) — the 'Values' admin screen — so a plain worker can ASSIGN existing values to a task (card.update on the task) but cannot create / rename / delete the value cards themselves. comm_channel / reply_body / activity_sink stay admin-only configuration surface." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
`[$role.worker, $role.manager]`, $card_type.task,              `[$process."card.create", $process."card.update", $process."comment.post", $process."user_card_sort.set"]`
`[$role.worker, $role.manager]`, $card_type.comm,              `[$process."card.create", $process."card.update", $process."comment.post", $process."user_card_sort.set"]`
`[$role.worker, $role.manager]`, $card_type.person,            `[$process."card.create", $process."card.update"]`
`[$role.worker, $role.manager]`, `[$card_type.project, $card_type.screen, $card_type.filter, $card_type.status, $card_type.predicate_snippet]`, `[$process."card.create", $process."card.update", $process."card.delete"]`


## table role_grant | doc="manager-only: CRUD on the enum_managed VALUE cards (milestone / component / tag) — the 'Values' admin screen. Workers are deliberately excluded (they assign existing values to tasks but don't curate the value set); admins get this via the admin grant below." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.manager, `[$card_type.milestone, $card_type.component, $card_type.tag]`, `[$process."card.create", $process."card.update", $process."card.delete"]`


## table role_grant | doc="admin grants: card.* + comment.post + user_card_sort.set across every built-in card_type. status is included so admins can manage value-cards for the flow kernel (V8: delete is gated against flow_step references). The three comm card_types (comm_channel, comm, reply_body) are admin-only configuration surface; managers get a lighter cut on comm via the manager grant." | on_conflict="role_id, card_type_id, process_id"
### rows
role_id, card_type_id, process_id
$role.admin, `[$card_type.project, $card_type.task, $card_type.milestone, $card_type.component, $card_type.tag, $card_type.person, $card_type.screen, $card_type.filter, $card_type.status, $card_type.comm_channel, $card_type.comm, $card_type.reply_body, $card_type.activity_sink, $card_type.predicate_snippet]`, `[$process."card.create", $process."card.update", $process."card.delete", $process."comment.post", $process."user_card_sort.set"]`


-- ---------------------------------------------------------------------
-- Standard Project Template (Gate 11 of docs/FLOW_AND_SCREEN_KERNEL.md)
--
-- The template is a real `project` card flagged `is_template=true`. It
-- carries the kernel default set: 6 status value-cards (one triage,
-- three active, two terminal), the standard `status` flow with its
-- default_create_status pointing at "New idea", 12 flow_step transitions,
-- and the 6 default screens (Inbox / Grid / Kanban / Project / Ideas /
-- Archive) with layouts, slugs, hotkeys, flow_refs, default_create_status
-- overrides and toggle_groups.
--
-- New projects are produced by `project.stamp` (Gate 10), which graph-
-- copies the template's value cards, flows, flow_steps, screens, and
-- filter children into the fresh project with ID remapping.
--
-- Idempotency: every row carries an explicit id and on_conflict="id" so a
-- re-apply of the install seed is a true no-op. The demo guard skips its
-- own load when ANY non-template project exists (see seed.go), so the
-- template's presence does not block dev / test fixture loads.

## table card | alias=tpl_project | doc="The template project itself. is_template=true marks it as a stamping source; the user-facing project list filters it out client-side (Gate 12)." | on_conflict="id"
### rows
id, card_type_id,        title,                          is_template
10, $card_type.project,  "Standard Project Template",    true


